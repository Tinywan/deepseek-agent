{
    "name": "deepseek/agent",
    "description": "PHP Agent framework for the DeepSeek API — text generation, streaming, tool calling, structured output, and FIM completion.",
    "type": "library",
    "license": "Apache-2.0",
    "require": {
        "php": ">=8.1"
    },
    "autoload": {
        "psr-4": {
            "DeepSeek\\Agent\\": "src/"
        },
        "files": [
            "src/functions.php"
        ]
    },
    "authors": [
        {
            "name": "Tinywan"
        }
    ],
    "require-dev": {
        "pestphp/pest": "^4.7"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
